<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="ReservaButtonStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@drawable/button_background</item>
        <item name="android:textColor">#FFFFFF</item> <!-- Blanco para buen contraste -->
        <item name="android:textSize">16sp</item>
        <item name="android:layout_marginTop">16dp</item> <!-- Más separación entre botones -->
        <item name="android:padding">14dp</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="CircularShape">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <!-- Cambiar la fuente predeterminada -->
        <item name="android:fontFamily">@font/oswald_font</item> <!-- Aquí se aplica la fuente globalmente -->
        <item name="android:textColor">#FFFFFF</item> <!-- Puedes definir otros estilos como el color del texto aquí -->
    </style>



    <style name="ShapeAppearance.App.CurvedImage" parent="ShapeAppearance.MaterialComponents.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <style name="HistorialHeaderStyle">
        <item name="android:padding">8dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Estilo para las celdas de la tabla -->
    <style name="HistorialCellStyle">
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textSize">14sp</item>
        <item name="android:padding">16dp</item> <!-- Añadimos padding para que las celdas no se vean tan apretadas -->
        <item name="android:background">@drawable/bg_table_cell_style</item> <!-- Fondo con bordes -->
    </style>

    <!-- Tema personalizado para el DatePickerDialog -->
    <style name="CustomDatePickerDialogTheme" parent="Theme.MaterialComponents.DayNight.Dialog">
        <item name="android:textColorPrimary">@android:color/white</item> <!-- Cambiar color de los días de la semana -->
        <item name="android:textColorSecondary">@android:color/holo_orange_dark</item> <!-- Cambiar color del mes y año -->
        <item name="android:textColorHighlight">@android:color/white</item> <!-- Cambiar color de los días seleccionados -->
        <item name="android:background">#121212</item> <!-- Fondo oscuro -->
    </style>



    <style name="AlertDialogCustom" parent="Theme.AppCompat.Light.Dialog.Alert">
        <item name="android:background">@drawable/bg_popup</item>
        <item name="android:elevation">6dp</item> <!-- Para asegurar que el diálogo tenga la sombra adecuada -->
    </style>
    <style name="ShapeAppearance">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <style name="CustomRadioButton" parent="Widget.MaterialComponents.CompoundButton.RadioButton">
        <item name="android:buttonTint">@color/orange</item>
    </style>

    <!-- Estilo para el diálogo -->
    <style name="ReservaDialogTheme" parent="Theme.AppCompat.Light.Dialog.Alert">
        <item name="android:background">@color/black</item>
        <item name="android:textColorPrimary">@color/white</item>
        <item name="android:buttonBarPositiveButtonStyle">@style/DialogoBotonPositivo</item>
        <item name="android:buttonBarNegativeButtonStyle">@style/DialogoBotonNegativo</item>
    </style>

    <!-- Botón positivo en naranja -->
    <style name="DialogoBotonPositivo" parent="Widget.AppCompat.Button.ButtonBar.AlertDialog">
        <item name="android:textColor">@color/orange</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Botón negativo blanco -->
    <style name="DialogoBotonNegativo" parent="Widget.AppCompat.Button.ButtonBar.AlertDialog">
        <item name="android:textColor">@color/white</item>
    </style>

</resources>
