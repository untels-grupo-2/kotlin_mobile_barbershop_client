<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- ScrollView para que la página completa sea desplazable -->
    <android.widget.ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">


            <ImageView
                android:id="@+id/imagenServicio"
                android:layout_width="0dp"
                android:layout_height="200dp"
                android:layout_marginTop="24dp"
                android:src="@drawable/barberia1"
                android:scaleType="centerCrop"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />


            <TextView
                android:id="@+id/textTituloServicio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Corte Low Fade"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginTop="24dp"
                app:layout_constraintTop_toBottomOf="@id/imagenServicio"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />


            <TextView
                android:id="@+id/textPrecioServicio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="S/ 25.5"
                android:textSize="18sp"
                android:textColor="#FFFFFF"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/textTituloServicio"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />


            <TextView
                android:id="@+id/textDescripcionServicio"
                android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Corte de Cabello"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/textPrecioServicio"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />


            <TextView
                android:id="@+id/textSedeServicio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SEDE: VILLA MARIA"
                android:textSize="16sp"
                android:textColor="#FF9800"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/textDescripcionServicio"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />


            <TextView
                android:id="@+id/textElegirBarbero"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Elegir Barbero"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toBottomOf="@id/textSedeServicio"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />


            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerViewBarberos"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toBottomOf="@id/textElegirBarbero"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toTopOf="@id/btnReservar"
                android:padding="16dp"
                android:layout_marginTop="16dp" />


            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnReservar"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:text="Reservar"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:backgroundTint="#FF9800"
                app:cornerRadius="12dp"
                app:layout_constraintBottom_toTopOf="@id/btnCancelar"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_margin="16dp" />


            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancelar"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:text="Cancelar"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:backgroundTint="#1E1E1E"
                app:cornerRadius="12dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_margin="16dp" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </android.widget.ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
